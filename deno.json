{
  "name": "@srdjan/sikret",
  "version": "0.1.0",
  "exports": "./mod.ts",
  "tasks": {
    "compile": "deno compile --allow-read --allow-env --allow-run --output ./bin/sikret cli.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-run",
    "check": "deno check mod.ts cli.ts cli_test.ts",
    "site": "deno run --allow-net --allow-read --allow-sys https://deno.land/std/http/file_server.ts public/ --port 8000"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
